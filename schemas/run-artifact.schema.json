{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Bench Run Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["harness", "task_id", "latency_ms", "cost_usd", "scores"],
  "properties": {
    "harness": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "task_version": {"type": "string", "minLength": 1},
    "harness_version": {"type": "string", "minLength": 1},
    "model_version": {"type": "string", "minLength": 1},
    "rubric_version": {"type": "string", "minLength": 1},
    "synthetic_data": {"type": "boolean"},
    "latency_ms": {"type": "number", "minimum": 0},
    "cost_usd": {"type": "number", "minimum": 0},
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_success", "output_quality", "observable_trace_quality"],
      "properties": {
        "task_success": {"type": "number", "minimum": 0, "maximum": 1},
        "output_quality": {"type": "number", "minimum": 0, "maximum": 1},
        "observable_trace_quality": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
